<!-- Audio de fondo -->
<audio id="bg-audio" loop>
  <source src="/audio/rev.mpeg" type="audio/mpeg" />
</audio>

<!-- Toast de notificaciones -->
<div id="toast-message" class="toast"></div>

<!-- ═══════════════════════════════════════════════════════════════
     INTRO OVERLAY
═══════════════════════════════════════════════════════════════ -->
<div id="intro-overlay" class="intro-overlay">
  <div class="intro-stars"></div>
  <div class="intro-content">
    <div class="intro-dragon-img"></div>
    <h1 class="intro-title">UNA NUEVA<br />AVENTURA<br />COMIENZA</h1>
    <p class="intro-subtitle">
      Daniel &amp; Lisseth<br />tienen un secreto que revelar...
    </p>
    <button id="btn-start" class="btn-start">
      ▶&nbsp;&nbsp;DESCUBRIR
    </button>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════
     CONTENIDO PRINCIPAL
═══════════════════════════════════════════════════════════════ -->
<div id="main-content" class="main-content hidden">

  <!-- HERO ─────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-energy-ring"></div>
    <div class="container hero-inner">
      <div class="hero-duo">
        <img src="/img/niña.png" alt="" class="hero-duo-img hero-duo-girl" onerror="this.style.display='none'" />
        <img src="/img/niño.png" alt="" class="hero-duo-img hero-duo-boy" onerror="this.style.display='none'" />
      </div>
      <div class="title-pers"><h1 class="hero-title-boy">¿NIÑO</h1>
      <h1 class="hero-title">O</h1></div>
      <h1 class="hero-title-girl">NIÑA?</h1>
      <div class="hero-parents-box">
        <span class="hero-parents">Daniel Solarte &amp; Lisseth Garzón</span>
      </div>
      <p class="hero-description">
        La espera está por terminar. Nuestro bebé está en camino y su poder aumenta
        como en una transformación saiyajin.<br />
        ¿Niño o niña? Ven a revelarlo junto a nosotros.
      </p>
    </div>
  </section>

  <!-- DETALLES DEL EVENTO ─────────────────────────────────────── -->
  <section class="event-details">
    <div class="container">

      <div class="event-blocks">

        <!-- Fecha y hora -->
        <div class="event-block">
          <div class="event-block-divider"><span>CUÁNDO</span></div>
          <div class="event-date-row">
            <div class="event-date-item">
              <span class="event-date-label">DÍA</span>
              <span class="event-date-value">Por confirmar</span>
            </div>
            <div class="event-date-sep"></div>
            <div class="event-date-item">
              <span class="event-date-label">MES</span>
              <span class="event-date-value">Por confirmar</span>
            </div>
            <div class="event-date-sep"></div>
            <div class="event-date-item">
              <span class="event-date-label">HORA</span>
              <span class="event-date-value">00:00 hrs</span>
            </div>
          </div>
        </div>

        <!-- Lugar -->
        <div class="event-block">
          <div class="event-block-divider"><span>DÓNDE</span></div>
          <p class="event-address">Calle 1 #1-1</p>
          <div class="map-wrap">
            <iframe
              src="https://www.google.com/maps?q=Calle+1+%231-1,+Cali,+Colombia&output=embed"
              width="100%"
              height="200"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación del evento">
            </iframe>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- PREDICCIÓN ─────────────────────────────────────────────── -->
  <section class="prediction-section">
    <div class="container">
      <h2 class="section-title">CONFIRMACIÓN</h2>
      <p class="section-description">
        Nos encantaría saber que nos acompañarás.<br />
        Permítenos preparar los detalles confirmando aquí.
      </p>
      <p class="section-subtitle">¡Elige tu equipo y confirma tu asistencia!</p>

      <div class="teams-grid">

        <!-- Equipo Niño -->
        <div class="team-card team-boy" onclick="openConfirmModal('boy')">
          <div class="team-glow glow-boy"></div>
          <div class="team-img-wrap">
            <img src="/img/niño.png" alt="Goku Bebé" class="team-img" onerror="this.style.display='none'" />
            {{!-- <div class="team-img-fallback"></div> --}}
          </div>
          <h3 class="team-name name-boy">EQUIPO NIÑO</h3>
          <p class="team-gift">🍼 Trae pañales</p>
          <button class="btn-team btn-boy">¡CONFIRMAR! 💙</button>
        </div>

        <!-- Equipo Niña -->
        <div class="team-card team-girl" onclick="openConfirmModal('girl')">
          <div class="team-glow glow-girl"></div>
          <div class="team-img-wrap">
            <img src="/img/niña.png" alt="Pan Bebé" class="team-img" onerror="this.style.display='none'" />
            {{!-- <div class="team-img-fallback"></div> --}}
          </div>
          <h3 class="team-name name-girl">EQUIPO NIÑA</h3>
          <p class="team-gift">🧻 Trae pañitos húmedos</p>
          <button class="btn-team btn-girl">¡CONFIRMAR! 💗</button>
        </div>

      </div>
    </div>
  </section>

  <!-- CONTADOR ──────────────────────────────────────────────── -->
  <section class="counter-section">
    <div class="container">
      <h2 class="section-title">GUERREROS Z CONFIRMADOS</h2>
      <div class="counter-total-wrap">
        <span id="total-count" class="counter-big">0</span>
        <span class="counter-big-label">guerreros confirmados</span>
      </div>
      <div class="vs-counter">
        <div class="vc-team vc-boy">
          <span class="vc-icon">💙</span>
          <span id="team-boy-count" class="vc-number">0</span>
          <span class="vc-label">Equipo Niño</span>
        </div>
        <div class="vc-divider">VS</div>
        <div class="vc-team vc-girl">
          <span class="vc-icon">💗</span>
          <span id="team-girl-count" class="vc-number">0</span>
          <span class="vc-label">Equipo Niña</span>
        </div>
      </div>
    </div>
  </section>

  <!-- DRAGÓN ─────────────────────────────────────────────────── -->
  <div class="dragon-section">
    <img src="/img/Dragon.png" alt="" class="dragon-center-img" onerror="this.style.display='none'" />
  </div>

  <!-- FOOTER ────────────────────────────────────────────────── -->
  <footer class="footer">
    <p class="footer-main">Te esperamos</p>
    <p class="footer-sub">Con amor, Daniel &amp; Lisseth</p>
  </footer>

</div><!-- /main-content -->

<!-- ═══════════════════════════════════════════════════════════════
     BANNER WHATSAPP
═══════════════════════════════════════════════════════════════ -->
<div id="whatsapp-banner" class="whatsapp-banner">
  <div class="whatsapp-banner-inner">
    <p class="whatsapp-banner-text">¡Confirmación guardada!<br />Toca el botón para enviar tu mensaje</p>
    <a id="whatsapp-banner-link" href="#" target="_blank" rel="noopener" class="whatsapp-banner-btn">
      Abrir WhatsApp
    </a>
    <button id="whatsapp-banner-close" class="whatsapp-banner-close">✕</button>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════
     MODAL DE CONFIRMACIÓN
═══════════════════════════════════════════════════════════════ -->
<div id="confirm-modal" class="modal-overlay" onclick="handleModalOverlayClick(event)">
  <div class="modal-card">
    <button class="modal-close" onclick="closeModal()">✕</button>

    <div class="modal-header">
      <span id="modal-pred-icon" class="modal-pred-icon">💙</span>
      <h2 class="modal-title">CONFIRMAR ASISTENCIA</h2>
      <p id="modal-pred-label" class="modal-pred-label label-boy">EQUIPO NIÑO</p>
    </div>

    <form id="confirm-form" onsubmit="return false;">
      <div class="form-group">
        <label for="guest-name">Nombre completo *</label>
        <input type="text" id="guest-name" placeholder="¿Cómo te llamas, guerrero/a?" required />
      </div>

      <div class="form-group">
        <label for="guest-phone">Teléfono <span class="label-optional">(opcional, evita duplicados)</span></label>
        <input type="tel" id="guest-phone" placeholder="Ej: 3001234567" />
      </div>

      <div class="form-group">
        <label for="guest-count">¿Cuántos asistirán?</label>
        <select id="guest-count">
          <option value="1">Solo yo (1 persona)</option>
          <option value="2">2 personas</option>
          <option value="3">3 personas</option>
          <option value="4">4 personas</option>
          <option value="5">5 personas</option>
          <option value="6">6 personas</option>
          <option value="7">7 personas</option>
          <option value="8">8 personas</option>
          <option value="9">9 personas</option>
          <option value="10">10 personas</option>
        </select>
      </div>

      <p id="form-error" class="form-error" style="display:none;"></p>

      <p class="modal-whatsapp-label">¿Con quién confirmas?</p>
      <div class="confirm-btn-group">
        <button type="button" class="btn-confirm btn-confirm-dad" onclick="handleConfirm('daniel')">
          📱 Papá Daniel
        </button>
        <button type="button" class="btn-confirm btn-confirm-mom" onclick="handleConfirm('lisseth')">
          📱 Mamá Lisseth
        </button>
      </div>
    </form>
  </div>
</div>

<script src="/js/main.js"></script>